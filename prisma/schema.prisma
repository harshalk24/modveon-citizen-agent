generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Citizen {
  id        String   @id @default(cuid())
  firstName String?
  country   String   @default("SV")
  email     String?
  gender    String?
  language  String   @default("en")
  onboarded Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions   Session[]
  context    CitizenContext?
  deadlines  Deadline[]
  actionPlan ActionPlan?
  feedbacks  Feedback[]
  logs       ResponseLog[]
}

model CitizenContext {
  id                  String   @id @default(cuid())
  citizenId           String   @unique
  lifeEvent           String?
  // Phase 2a (concurrent situations): source of truth for which situations
  // are active — a JSON array of slugs, e.g. ["new-baby","job-loss"]. `lifeEvent`
  // is retained as a compat "primary (most-recently-added)" field so existing
  // singular readers keep working; both are written through lib/situations.ts
  // so they never drift. Full migration off `lifeEvent` is Phase 2b.
  activeLifeEvents    String   @default("[]")
  pendingLifeEvent    String?
  employment          String?
  // Explicit-capture only (Task A) — set via the profile-save form, not
  // inferred from chat, so it's ungated like lifeEvent/employment in that
  // same explicit-save path. Used to personalize phrasing/location context,
  // never to fabricate a per-municipality KB fact that doesn't exist.
  municipality        String?
  entitlementsJson    String   @default("[]")
  conversationSummary String?
  // Slot-filling (Task S1) — decision-relevant facts for the CURRENT situation
  // only (not episodic history). slotsJson e.g. {"businessSizeTier":"solo"}.
  // pendingSlot is the key of the slot the last turn's question asked about,
  // so the next reply can be parsed as its answer — cleared together with
  // slotsJson whenever lifeEvent changes (same "new situation, clean slate"
  // reasoning already applied to entitlementsJson).
  slotsJson           String   @default("{}")
  pendingSlot         String?
  updatedAt           DateTime @updatedAt

  citizen Citizen @relation(fields: [citizenId], references: [id])
}

model ActionPlan {
  id        String   @id @default(cuid())
  citizenId String   @unique
  planJson  String   @default("[]")
  lifeEvent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  citizen Citizen @relation(fields: [citizenId], references: [id])
}

model Deadline {
  id          String   @id @default(cuid())
  citizenId   String
  title       String
  titleEs     String
  dueDate     DateTime
  serviceName String
  serviceId   String
  completed   Boolean  @default(false)
  reminded30  Boolean  @default(false)
  reminded7   Boolean  @default(false)
  reminded1   Boolean  @default(false)
  createdAt   DateTime @default(now())

  citizen Citizen @relation(fields: [citizenId], references: [id])
}

model Session {
  id        String   @id @default(cuid())
  citizenId String?
  messages  String   @default("[]")
  turnCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  citizen Citizen? @relation(fields: [citizenId], references: [id])
}

model Feedback {
  id        String   @id @default(cuid())
  citizenId String?
  serviceId String?
  messageId String?
  type      String
  note      String?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  citizen Citizen? @relation(fields: [citizenId], references: [id])
}

model ResponseLog {
  id          String   @id @default(cuid())
  citizenId   String?
  sessionId   String?
  prompt      String
  response    String
  kbSourceIds String   @default("[]")
  model       String   @default("gemini-2.5-flash-lite")
  latencyMs   Int?
  createdAt   DateTime @default(now())

  citizen Citizen? @relation(fields: [citizenId], references: [id])
}

// Task M1 — measures the grounding fallback rate. Written only for turns that
// did NOT pass grounding on the first attempt, so a human can hand-judge
// legitimate-catch vs. over-strict-judge from real material. No FK relation to
// Citizen (deliberately) — this is diagnostic/measurement data, not part of a
// citizen's own record, and must never block a test citizen's cleanup deletion.
model GroundingFallback {
  id           String   @id @default(cuid())
  citizenId    String?
  sessionId    String?
  query        String
  // JSON array of {attempt, draft, stage, reasons, passed} — untruncated, one
  // entry per generation attempt for this turn (1 or 2).
  attemptsJson String
  outcome      String   // "regenerated" | "fell-back"
  finalReply   String
  createdAt    DateTime @default(now())
}

model KBChangeLog {
  id         String   @id @default(cuid())
  serviceId  String
  field      String
  oldValue   String?
  newValue   String?
  changedBy  String   @default("manual")
  verifiedAt DateTime @default(now())
  note       String?
}
