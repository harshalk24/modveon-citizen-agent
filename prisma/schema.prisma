generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Citizen {
  id        String   @id @default(cuid())
  firstName String?
  country   String   @default("SV")
  email     String?
  gender    String?
  language  String   @default("en")
  onboarded Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions      Session[]
  context       CitizenContext?
  situations    Situation[]
  deadlines     Deadline[]
  actionPlan    ActionPlan?
  feedbacks     Feedback[]
  logs          ResponseLog[]
  conversations Conversation[]
}

// Task History-C1 — durable conversation history (Version A, device-scoped,
// no auth). Distinct from the live Redis session (lib/session.ts, 24h TTL,
// ephemeral) — this is the permanent record a citizen can revisit later.
// The Redis session carries the active conversationId; each chat turn
// write-throughs to that conversation's rows here.
model Conversation {
  id        String   @id @default(cuid())
  citizenId String
  title     String
  // Task TITLE_OFF_HOTPATH: idempotency guard for the client-triggered
  // title-upgrade endpoint — true only once the LLM title has actually been
  // written, so a retried/duplicate client call (or a client that fires the
  // request more than once) is a true no-op instead of a repeated LLM call.
  titleUpgraded Boolean @default(false)
  // Task I18N_PER_CONVERSATION: fixed at creation (the global UI pref at that
  // moment) and never changes for the conversation's life — every turn in the
  // thread renders/generates in THIS language, not whatever the global toggle
  // is showing right now. Prevents mixed-language history (already-persisted
  // messages can't be retroactively translated if the toggle flips mid-thread).
  // Default "es" — the product is Spanish-first; existing rows backfill to it.
  language  String   @default("es")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  citizen   Citizen  @relation(fields: [citizenId], references: [id])
  messages  Message[]
  @@index([citizenId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // "user" | "assistant"
  content        String
  createdAt      DateTime @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  @@index([conversationId])
}

// Task 2b-C1 — per-situation state, one row per concurrently-active
// situation (Phase 2a's `activeLifeEvents` moves here). `CitizenContext`
// keeps the per-citizen fields (employment, municipality, conversationSummary,
// and `lifeEvent` as the compat "primary = most-recently-added" pointer) —
// see lib/situation-store.ts for the read/write funnel. `status` distinguishes
// "active" from a later resolved state; a removed situation's row is DELETED
// outright (see lib/situations.ts's removeSituation semantics), never just
// marked — there's nothing to keep once a situation is dropped.
model Situation {
  id               String   @id @default(cuid())
  citizenId        String
  lifeEvent        String
  slotsJson        String   @default("{}")
  entitlementsJson String   @default("[]")
  pendingSlot      String?
  status           String   @default("active") // active | resolved; removed = row DELETED
  addedAt          DateTime @default(now())
  updatedAt        DateTime @updatedAt
  citizen          Citizen  @relation(fields: [citizenId], references: [id])

  @@unique([citizenId, lifeEvent])
}

model CitizenContext {
  id                  String   @id @default(cuid())
  citizenId           String   @unique
  lifeEvent           String?
  // Phase 2a (concurrent situations): source of truth for which situations
  // are active — a JSON array of slugs, e.g. ["new-baby","job-loss"]. `lifeEvent`
  // is retained as a compat "primary (most-recently-added)" field so existing
  // singular readers keep working; both are written through lib/situations.ts
  // so they never drift. Full migration off `lifeEvent` is Phase 2b.
  activeLifeEvents    String   @default("[]")
  pendingLifeEvent    String?
  employment          String?
  // Explicit-capture only (Task A) — set via the profile-save form, not
  // inferred from chat, so it's ungated like lifeEvent/employment in that
  // same explicit-save path. Used to personalize phrasing/location context,
  // never to fabricate a per-municipality KB fact that doesn't exist.
  municipality        String?
  entitlementsJson    String   @default("[]")
  conversationSummary String?
  // Slot-filling (Task S1) — decision-relevant facts for the CURRENT situation
  // only (not episodic history). slotsJson e.g. {"businessSizeTier":"solo"}.
  // pendingSlot is the key of the slot the last turn's question asked about,
  // so the next reply can be parsed as its answer — cleared together with
  // slotsJson whenever lifeEvent changes (same "new situation, clean slate"
  // reasoning already applied to entitlementsJson).
  slotsJson           String   @default("{}")
  pendingSlot         String?
  updatedAt           DateTime @updatedAt

  citizen Citizen @relation(fields: [citizenId], references: [id])
}

model ActionPlan {
  id        String   @id @default(cuid())
  citizenId String   @unique
  planJson  String   @default("[]")
  lifeEvent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  citizen Citizen @relation(fields: [citizenId], references: [id])
}

model Deadline {
  id          String   @id @default(cuid())
  citizenId   String
  title       String
  titleEs     String
  dueDate     DateTime
  serviceName String
  serviceId   String
  completed   Boolean  @default(false)
  reminded30  Boolean  @default(false)
  reminded7   Boolean  @default(false)
  reminded1   Boolean  @default(false)
  createdAt   DateTime @default(now())

  citizen Citizen @relation(fields: [citizenId], references: [id])
}

model Session {
  id        String   @id @default(cuid())
  citizenId String?
  messages  String   @default("[]")
  turnCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  citizen Citizen? @relation(fields: [citizenId], references: [id])
}

model Feedback {
  id        String   @id @default(cuid())
  citizenId String?
  serviceId String?
  messageId String?
  type      String
  note      String?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  citizen Citizen? @relation(fields: [citizenId], references: [id])
}

model ResponseLog {
  id          String   @id @default(cuid())
  citizenId   String?
  sessionId   String?
  prompt      String
  response    String
  kbSourceIds String   @default("[]")
  model       String   @default("gemini-2.5-flash-lite")
  latencyMs   Int?
  createdAt   DateTime @default(now())

  citizen Citizen? @relation(fields: [citizenId], references: [id])
}

// Task M1 — measures the grounding fallback rate. Written only for turns that
// did NOT pass grounding on the first attempt, so a human can hand-judge
// legitimate-catch vs. over-strict-judge from real material. No FK relation to
// Citizen (deliberately) — this is diagnostic/measurement data, not part of a
// citizen's own record, and must never block a test citizen's cleanup deletion.
model GroundingFallback {
  id           String   @id @default(cuid())
  citizenId    String?
  sessionId    String?
  query        String
  // JSON array of {attempt, draft, stage, reasons, passed} — untruncated, one
  // entry per generation attempt for this turn (1 or 2).
  attemptsJson String
  outcome      String   // "regenerated" | "fell-back"
  finalReply   String
  createdAt    DateTime @default(now())
}

model KBChangeLog {
  id         String   @id @default(cuid())
  serviceId  String
  field      String
  oldValue   String?
  newValue   String?
  changedBy  String   @default("manual")
  verifiedAt DateTime @default(now())
  note       String?
}
